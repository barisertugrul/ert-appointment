.blist li::before{content:'›';color:var(--accent);font-weight:700;flex-shrink:0;margin-top:1px}

/* Callouts */
.call{display:flex;gap:12px;align-items:flex-start;padding:14px 18px;border-radius:8px;margin:16px 0;font-size:.875rem;line-height:1.6;border-left:3px solid}
.call-icon{flex-shrink:0;font-size:15px;margin-top:1px}
.call-body{color:var(--text2)}
.call-info{background:rgba(47,129,247,.08);border-color:var(--accent)}
.call-warn{background:rgba(210,153,34,.08);border-color:var(--gold)}
.call-tip{background:rgba(63,185,80,.08);border-color:var(--green)}
.ci{font-family:var(--mono);font-size:.82em;color:var(--accent);background:rgba(47,129,247,.1);padding:2px 7px;border-radius:4px;border:1px solid rgba(47,129,247,.2)}
.vt{font-family:var(--mono);font-size:12px;color:#50fa7b;background:rgba(80,250,123,.1);border:1px solid rgba(80,250,123,.2);padding:2px 8px;border-radius:4px}

/* Code */
.cb{position:relative;background:#0d1117;border:1px solid var(--border);border-radius:8px;margin:16px 0;overflow:hidden}
.ch{display:flex;align-items:center;justify-content:space-between;padding:8px 14px;background:var(--bg2);border-bottom:1px solid var(--border);font-family:var(--mono);font-size:11.5px;color:var(--text3)}
.dots{display:flex;gap:5px}
.dots span{width:10px;height:10px;border-radius:50%}
.dots span:nth-child(1){background:#ff5f57}
.dots span:nth-child(2){background:#ffbd2e}
.dots span:nth-child(3){background:#28c840}
.ccopy{background:none;border:none;cursor:pointer;color:var(--text3);font-size:12px;font-family:var(--mono);padding:2px 6px;border-radius:4px;transition:color .15s,background .15s}
.ccopy:hover{color:var(--text);background:var(--border)}
pre{padding:18px 20px;overflow-x:auto;font-family:var(--mono);font-size:13px;line-height:1.65;color:#a8d8ea;tab-size:2}
.kw{color:#ff79c6}.str{color:#f1fa8c}.fn{color:#50fa7b}.cm{color:#6272a4;font-style:italic}.nm{color:#bd93f9}.rx{color:#8be9fd}

/* Shortcode box */
.sc{display:inline-flex;align-items:center;gap:10px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:12px 20px;font-family:var(--mono);font-size:16px;color:var(--accent);margin:8px 0 16px;cursor:pointer;transition:border-color .2s}
.sc:hover{border-color:var(--accent)}

/* Progress */
.prog{position:fixed;top:56px;left:0;right:0;z-index:99;height:2px;background:linear-gradient(90deg,var(--accent),var(--purple));transform-origin:left;transform:scaleX(0);transition:transform .05s}

/* Footer */
.foot{margin-left:var(--sw);padding:24px 48px;border-top:1px solid var(--border2);display:flex;align-items:center;justify-content:space-between;font-size:12.5px;color:var(--text3);flex-wrap:wrap;gap:12px}

/* Lang */
[data-lang=en] .tro{display:none!important}
[data-lang=tr] .eno{display:none!important}

/* Search highlight */
mark{background:rgba(210,153,34,.35);color:var(--gold);border-radius:2px;padding:0 2px}

/* Responsive */
