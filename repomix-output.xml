<template>
  <div class="erta-my-appointments">
    <h3 class="erta-section-title">{{ t('myAppointments') }}</h3>

    <!-- Tab: Upcoming / Past -->
    <div class="erta-tabs">
      <button
        class="erta-tab"
        :class="{ 'erta-tab--active': activeTab === 'upcoming' }"
