  cursor: pointer;
  border: none;
  text-decoration: none;
  transition: all .15s;
}

.erta-btn--primary  { background: var(--erta-primary);    color: #fff; }
.erta-btn--primary:hover { background: var(--erta-primary-dark); }
.erta-btn--danger   { background: var(--erta-danger);     color: #fff; }
.erta-btn--ghost    { background: #fff; border: 1.5px solid var(--erta-gray-200); color: var(--erta-gray-800); }
.erta-btn--ghost:hover { border-color: var(--erta-gray-500); }
.erta-btn--sm       { padding: 5px 12px; font-size: .82rem; }

/* ── Pro badge / lock ────────────────────────────────────────────────────── */
.erta-pro-badge {
  display: inline-block;
  padding: 1px 7px;
  background: linear-gradient(135deg, #f59e0b, #d97706);
  color: #fff;
  border-radius: 4px;
  font-size: .72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .04em;
  margin-left: 6px;
}

.erta-pro-gate {
  opacity: .5;
  pointer-events: none;
  position: relative;
}

.erta-pro-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,.7);
  border-radius: var(--erta-radius);
  pointer-events: all;
}

.erta-pro-upgrade-card {
  background: linear-gradient(135deg, #eff6ff, #dbeafe);
  border: 1.5px solid #93c5fd;
  border-radius: var(--erta-radius);
  padding: 20px 24px;
  text-align: center;
}

/* ── Alert ───────────────────────────────────────────────────────────────── */
.erta-alert {
  padding: 12px 16px;
  border-radius: 6px;
  margin-bottom: 16px;
  font-size: .9rem;
}

.erta-alert--error   { background: #fee2e2; color: #991b1b; }
.erta-alert--success { background: #d1fae5; color: #065f46; }
.erta-alert--info    { background: #dbeafe; color: #1e40af; }

/* ── Installation checklist (settings) ──────────────────────────────────── */
.erta-install-checklist-wrap {
  margin-bottom: 20px;
}

.erta-install-checklist__toggle {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  border: 1px solid var(--erta-gray-200);
  background: #fff;
  border-radius: var(--erta-radius);
  padding: 10px 12px;
  cursor: pointer;
  font-weight: 600;
}

.erta-install-checklist__panel {
  margin-top: 10px;
}

.erta-install-checklist {
  background: #fff;
  border: 1px solid var(--erta-gray-200);
  border-radius: var(--erta-radius);
}

.erta-install-checklist__actions {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
}

.erta-install-checklist__item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 10px 12px;
  border-bottom: 1px solid var(--erta-gray-200);
}

.erta-install-checklist__item:last-child {
  border-bottom: none;
}

/* ── Working hours grid ──────────────────────────────────────────────────── */
.erta-hours-grid { display: flex; flex-direction: column; gap: 10px; }
.erta-hours-row  { display: flex; align-items: center; gap: 12px; }
.erta-hours-day  { width: 100px; font-weight: 500; font-size: .9rem; }
.erta-hours-time { display: flex; align-items: center; gap: 8px; }

/* ── Sidebar ──────────────────────────────────────────────────────────────── */
.erta-admin-wrap { display: flex; min-height: 80vh; gap: 0; }
.erta-sidebar { width: 220px; flex-shrink: 0; background: #1e293b; padding: 0; }
.erta-sidebar__brand { padding: 20px 16px; color: #fff; font-weight: 700; font-size: 1rem; border-bottom: 1px solid rgba(255,255,255,.1); }
.erta-nav { list-style: none; margin: 0; padding: 8px 0; }
.erta-nav__item {
  display: flex; align-items: center; gap: 10px;
  width: 100%; padding: 10px 16px;
  border: none; background: none; color: #94a3b8;
  font-size: .9rem; cursor: pointer; text-align: left;
  transition: background .15s, color .15s;
}
.erta-nav__item:hover { background: rgba(255,255,255,.05); color: #fff; }
.erta-nav__item--active { background: rgba(37,99,235,.3); color: #60a5fa; }
.erta-nav__icon { font-size: 1rem; }
.erta-admin-content { flex: 1; padding: 28px 32px; background: #fff; min-height: 80vh; }

/* ── Filters ──────────────────────────────────────────────────────────────── */
.erta-filters { display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
.erta-filters .erta-input { max-width: 200px; }

/* ── Pagination ───────────────────────────────────────────────────────────── */
.erta-pagination { display: flex; align-items: center; gap: 12px; justify-content: center; margin-top: 20px; color: var(--erta-gray-500); }

/* ── Admin modals ─────────────────────────────────────────────────────────── */
.erta-modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, .35);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  z-index: 100000;
}

.erta-modal {
  width: min(560px, 100%);
  background: #fff;
  border: 1px solid var(--erta-gray-200);
  border-radius: var(--erta-radius);
  padding: 18px;
  box-shadow: var(--erta-shadow-md);
}

.erta-modal h4 {
  margin: 0 0 14px;
  font-size: 1rem;
  color: var(--erta-gray-800);
}

.erta-form-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 12px;
}

.erta-form-field:last-of-type {
  margin-bottom: 0;
}

.erta-form-field .erta-form-label {
  margin: 0;
  font-size: .85rem;
  font-weight: 600;
  color: var(--erta-gray-600);
}

.erta-modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-top: 16px;
}

/* ── Action buttons ───────────────────────────────────────────────────────── */
.erta-action-btns { display: flex; gap: 4px; }
.erta-empty-cell { text-align: center; color: var(--erta-gray-500); padding: 24px !important; }

/* ── Detail table ─────────────────────────────────────────────────────────── */
.erta-detail-table { width: 100%; border-collapse: collapse; }
.erta-detail-table th { text-align: left; padding: 8px 12px; color: var(--erta-gray-500); font-weight: 500; width: 140px; border-bottom: 1px solid var(--erta-gray-200); }
.erta-detail-table td { padding: 8px 12px; border-bottom: 1px solid var(--erta-gray-200); }
.erta-modal--wide { max-width: 560px; }

/* ── Toggle switch ────────────────────────────────────────────────────────── */
.erta-toggle { position: relative; display: inline-block; width: 44px; height: 24px; }
.erta-toggle input { opacity: 0; width: 0; height: 0; }
.erta-toggle__slider { position: absolute; inset: 0; background: var(--erta-gray-200); border-radius: 24px; cursor: pointer; transition: .2s; }
.erta-toggle__slider::before { content: ''; position: absolute; height: 18px; width: 18px; left: 3px; bottom: 3px; background: #fff; border-radius: 50%; transition: .2s; }
.erta-toggle input:checked + .erta-toggle__slider { background: var(--erta-primary); }
.erta-toggle input:checked + .erta-toggle__slider::before { transform: translateX(20px); }

/* ── Form builder ─────────────────────────────────────────────────────────── */
.erta-field-list { display: flex; flex-direction: column; gap: 8px; }
.erta-field-item { display: flex; align-items: center; gap: 10px; padding: 10px; background: var(--erta-gray-50); border-radius: 6px; border: 1px solid var(--erta-gray-200); }
.erta-field-item__handle { cursor: grab; color: var(--erta-gray-500); font-size: 1.2rem; }
.erta-field-item__content { display: flex; gap: 8px; flex: 1; align-items: center; flex-wrap: wrap; }

/* ── Form Builder ────────────────────────────────────────────────────────── */
.erta-builder-meta {
  max-width: 600px;
  margin-bottom: 24px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--erta-gray-200);
}

.erta-builder-layout {
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 20px;
  margin-bottom: 28px;
}

/* Palette (left column) */
.erta-builder-palette {
  background: var(--erta-gray-50);
  border: 1px solid var(--erta-gray-200);
  border-radius: var(--erta-radius);
  padding: 14px;
}

.erta-palette-title {
  font-size: .8rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .05em;
  color: var(--erta-gray-500);
  margin: 0 0 10px;
}

.erta-palette-item {
  display: flex;
  align-items: center;
  gap: 8px;
  width: 100%;
  padding: 8px 10px;
  border: none;
  border-radius: 6px;
  background: #fff;
  cursor: pointer;
  font-size: .85rem;
  margin-bottom: 4px;
  border: 1px solid transparent;
  text-align: left;
  transition: all var(--erta-transition);
}

.erta-palette-item:hover {
  border-color: var(--erta-primary);
  color: var(--erta-primary);
}

.erta-palette-item__icon { font-size: 1rem; }
.erta-palette-item__label { flex: 1; }

/* Canvas (right column) */
.erta-builder-canvas {
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-height: 200px;
}

.erta-canvas-empty {
  padding: 40px;
  text-align: center;
  color: var(--erta-gray-500);
  border: 2px dashed var(--erta-gray-200);
  border-radius: var(--erta-radius);
}

/* Field cards */
.erta-field-card {
  background: #fff;
  border: 1.5px solid var(--erta-gray-200);
  border-radius: var(--erta-radius);
  overflow: hidden;
  cursor: pointer;
  transition: border-color var(--erta-transition);
}

.erta-field-card--active  { border-color: var(--erta-primary); }
.erta-field-card--system  { background: #f8fafc; }

.erta-field-card__header {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
}

.erta-field-card__drag      { color: var(--erta-gray-500); cursor: grab; font-size: 1.1rem; }
.erta-field-card__type-badge {
  background: var(--erta-gray-100);
  padding: 2px 8px;
  border-radius: 4px;
  font-size: .75rem;
  font-weight: 600;
  color: var(--erta-gray-500);
}
.erta-field-card__label { flex: 1; font-size: .9rem; font-weight: 500; }
.erta-field-card__actions { display: flex; gap: 4px; }

/* Field editor (expanded) */
.erta-field-editor {
  padding: 14px 16px;
  border-top: 1px solid var(--erta-gray-200);
  background: #fafbff;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.erta-fe-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.erta-fe-row--inline { gap: 14px; }
.erta-fe-label { width: 90px; font-size: .82rem; font-weight: 500; flex-shrink: 0; color: var(--erta-gray-500); }

.erta-options-list { display: flex; flex-direction: column; gap: 6px; }
.erta-option-row   { display: flex; align-items: center; gap: 8px; }

.erta-icon-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28px; height: 28px;
  border: 1.5px solid var(--erta-gray-200);
  border-radius: 5px;
  background: #fff;
  cursor: pointer;
  font-size: .85rem;
  transition: all var(--erta-transition);
}

.erta-icon-btn:hover { border-color: var(--erta-gray-500); }
.erta-icon-btn--danger { border-color: #fca5a5; color: var(--erta-danger); }
.erta-icon-btn--danger:hover { background: var(--erta-danger); color: #fff; border-color: var(--erta-danger); }

/* Preview panel */
.erta-builder-preview {
  max-width: 480px;
  border: 1.5px solid var(--erta-gray-200);
  border-radius: var(--erta-radius);
  padding: 20px 24px;
  background: var(--erta-gray-50);
}

.erta-preview-title {
  font-size: .85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .04em;
  color: var(--erta-gray-500);
  margin: 0 0 16px;
}

.erta-preview-fields { display: flex; flex-direction: column; gap: 14px; }
.erta-preview-field  { display: flex; flex-direction: column; gap: 4px; }
.erta-field-help { font-size: .8rem; color: var(--erta-gray-500); margin: 2px 0 0; }

.erta-input--mono { font-family: monospace; font-size: .85rem; }

.erta-actions-cell { display: flex; gap: 6px; }

/* ── Working Hours ────────────────────────────────────────────────────────── */
.erta-scope-bar {
  background: var(--erta-gray-50);
  border: 1px solid var(--erta-gray-200);
  border-radius: var(--erta-radius);
  padding: 14px 18px;
  margin-bottom: 20px;
}

.erta-scope-hint {
  font-size: .82rem;
  color: var(--erta-gray-500);
  margin: 6px 0 0;
}

.erta-wh-section { padding-top: 8px; }
.erta-section-hint {
  font-size: .85rem;
  color: var(--erta-gray-500);
  margin: 0 0 16px;
}

/* Hours grid */
.erta-hours-grid { display: flex; flex-direction: column; gap: 10px; max-width: 560px; }

.erta-hours-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 14px;
  background: #fff;
  border: 1px solid var(--erta-gray-200);
  border-radius: 8px;
}

.erta-hours-day {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 140px;
  flex-shrink: 0;
}

.erta-hours-day__label { font-weight: 500; font-size: .9rem; }
.erta-hours-day__label--closed { color: var(--erta-gray-500); }

.erta-hours-sep { color: var(--erta-gray-500); }
.erta-hours-closed { color: var(--erta-gray-500); font-style: italic; font-size: .85rem; }

.erta-input--time { width: 110px; }
.erta-input--date { width: 150px; }
.erta-input--narrow { width: 180px; }
.erta-form-row.erta-form-row--inline {
  display: flex;
  grid-template-columns: none;
  align-items: center;
  gap: 10px;
  padding: 0;
  border-bottom: none;
}

.erta-form-row.erta-form-row--inline .erta-form-label {
  padding-top: 0;
  white-space: nowrap;
}

/* Breaks */
.erta-break-list, .erta-special-list { display: flex; flex-direction: column; gap: 10px; max-width: 700px; }

.erta-break-card, .erta-special-card {
  background: #fff;
  border: 1px solid var(--erta-gray-200);
  border-radius: 8px;
  padding: 12px 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.erta-break-card__header { display: flex; align-items: center; gap: 10px; }
.erta-break-card__row    { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.erta-special-card__row  { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.erta-special-card__hours { display: flex; align-items: center; gap: 10px; margin-left: 160px; }

.erta-empty-hint {
  padding: 20px;
  text-align: center;
  color: var(--erta-gray-500);
  background: var(--erta-gray-50);
  border-radius: var(--erta-radius);
  font-size: .9rem;
}

/* Toggle switch */
.erta-toggle {
  position: relative;
  display: inline-flex;
  cursor: pointer;
}

.erta-toggle input { position: absolute; opacity: 0; width: 0; height: 0; }

.erta-toggle__slider {
  display: block;
  width: 36px; height: 20px;
  background: var(--erta-gray-200);
  border-radius: 20px;
  transition: background var(--erta-transition);
  position: relative;
}

.erta-toggle__slider::after {
  content: '';
  position: absolute;
  width: 14px; height: 14px;
  background: #fff;
  border-radius: 50%;
  top: 3px; left: 3px;
  transition: transform var(--erta-transition);
  box-shadow: 0 1px 3px rgba(0,0,0,.2);
}

.erta-toggle input:checked ~ .erta-toggle__slider { background: var(--erta-primary); }
.erta-toggle input:checked ~ .erta-toggle__slider::after { transform: translateX(16px); }

.erta-toggle--sm .erta-toggle__slider { width: 30px; height: 16px; }
.erta-toggle--sm .erta-toggle__slider::after { width: 10px; height: 10px; }
.erta-toggle--sm input:checked ~ .erta-toggle__slider::after { transform: translateX(14px); }

/* Scope badge */
.erta-badge--scope { background: #e0e7ff; color: #3730a3; }

/* ── Integration Cards ───────────────────────────────────────────────────── */
.erta-integration-card {
  border: 1.5px solid var(--erta-gray-200);
  border-radius: var(--erta-radius);
  margin-bottom: 20px;
  overflow: hidden;
  background: #fff;
}

.erta-integration-card__header {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 16px 20px;
  background: var(--erta-gray-50);
  border-bottom: 1px solid var(--erta-gray-200);
}

.erta-integration-card__icon { font-size: 1.6rem; flex-shrink: 0; }

.erta-integration-card__title {
  font-size: 1rem;
  font-weight: 600;
  margin: 0 0 2px;
}

.erta-integration-card__desc {
  font-size: .82rem;
  color: var(--erta-gray-500);
  margin: 0;
}

.erta-integration-card__header .erta-badge { margin-left: auto; }

.erta-integration-card__body {
  padding: 16px 20px;
}

.erta-integration-card__actions {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 20px;
  border-top: 1px solid var(--erta-gray-200);
  background: var(--erta-gray-50);
}

.erta-integration-ok  { font-size: .85rem; color: var(--erta-success); font-weight: 500; }
.erta-integration-err { font-size: .85rem; color: var(--erta-danger);  font-weight: 500; }

.erta-code-block {
  display: inline-block;
  padding: 6px 12px;
  background: var(--erta-gray-100);
  border: 1px solid var(--erta-gray-200);
  border-radius: 5px;
  font-family: monospace;
  font-size: .82rem;
  word-break: break-all;
  max-width: 100%;
}

/* ── Notifications page ───────────────────────────────────────────────────── */
.erta-notif-group {
  margin-bottom: 28px;
}

.erta-notif-group__title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: .95rem;
  font-weight: 600;
  color: var(--erta-gray-700);
  margin-bottom: 8px;
}

.erta-notif-event-icon { font-size: 1.1rem; }

.erta-notif-subject {
  max-width: 260px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: .85rem;
  color: var(--erta-gray-500);
}

.erta-quick-combos {
  margin-bottom: 16px;
  border: 1px solid var(--erta-gray-200);
  border-radius: var(--erta-radius);
  background: #fff;
  overflow: hidden;
}

.erta-quick-combos__summary {
  list-style: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 12px 14px;
  font-weight: 600;
  color: var(--erta-gray-800);
  cursor: pointer;
  background: var(--erta-gray-50);
  border-bottom: 1px solid var(--erta-gray-200);
}

.erta-quick-combos__summary::-webkit-details-marker { display: none; }

.erta-quick-combos__hint {
  font-size: .78rem;
  font-weight: 500;
  color: var(--erta-gray-500);
}

.erta-quick-combos__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 10px;
  padding: 12px;
}

.erta-quick-combos__btn {
  min-height: 58px;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  gap: 2px;
  text-align: left;
  padding: 10px 12px;
  border: 1.5px solid var(--erta-gray-200);
  border-radius: 8px;
  background: #fff;
  color: var(--erta-gray-800);
  cursor: pointer;
  transition: all var(--erta-transition);
}

.erta-quick-combos__btn:hover:not(:disabled) {
  border-color: var(--erta-primary);
  background: #eff6ff;
}

.erta-quick-combos__btn:disabled {
  cursor: not-allowed;
  opacity: .6;
}

.erta-quick-combos__btn-event {
  font-size: .85rem;
  font-weight: 600;
  line-height: 1.2;
}

.erta-quick-combos__btn-action {
  font-size: .76rem;
  color: var(--erta-gray-500);
  line-height: 1.2;
}

/* Editor layout */
.erta-editor-layout {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 24px;
  align-items: start;
}

.erta-editor-form { display: flex; flex-direction: column; gap: 16px; }
.erta-form-row--stacked { flex-direction: column; align-items: flex-start; gap: 6px; }
.erta-form-row--stacked .erta-form-label { width: auto; }

.erta-textarea-wrap { width: 100%; }

/* Sidebar */
.erta-editor-sidebar { display: flex; flex-direction: column; gap: 20px; }
.erta-sidebar-title  {
  font-size: .82rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .04em;
  color: var(--erta-gray-500);
  margin: 0 0 10px;
}

/* Placeholder chips */
.erta-placeholder-panel {
  border: 1px solid var(--erta-gray-200);
  border-radius: var(--erta-radius);
  padding: 14px;
  background: var(--erta-gray-50);
}

.erta-placeholder-list {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
}

.erta-placeholder-chip {
  background: #fff;
  border: 1.5px solid var(--erta-gray-200);
  border-radius: 5px;
  padding: 3px 8px;
  font-family: monospace;
  font-size: .75rem;
  cursor: pointer;
  transition: all var(--erta-transition);
  color: var(--erta-primary);
}

.erta-placeholder-chip:hover {
  border-color: var(--erta-primary);
  background: #eff6ff;
}

.erta-fieldset-reset {
  border: 0;
  margin: 0;
  padding: 0;
  min-width: 0;
}

/* Live preview */
.erta-preview-panel {
  border: 1px solid var(--erta-gray-200);
  border-radius: var(--erta-radius);
  padding: 14px;
  background: #fff;
}

.erta-email-preview {
  font-size: .85rem;
  border: 1px solid var(--erta-gray-200);
  border-radius: 6px;
  overflow: hidden;
}

.erta-email-preview__subject {
  background: var(--erta-gray-50);
  padding: 8px 12px;
