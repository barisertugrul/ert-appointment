              <label class="erta-fe-label">{{ t('day') }}</label>
              <select class="erta-input erta-input--narrow" v-model="brk.day_of_week">
                <option :value="null">{{ t('everyDay') }}</option>
                <option v-for="d in 7" :key="d" :value="d">{{ dayName(d) }}</option>
