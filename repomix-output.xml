          <button
            v-if="appt.is_reschedulable"
            class="erta-btn erta-btn--sm erta-btn--ghost"
            @click="openReschedule(appt)"
          >{{ t('reschedule') }}</button>
          <button
            v-if="appt.is_cancellable"
            class="erta-btn erta-btn--sm erta-btn--danger"
            @click="openCancel(appt)"
          >{{ t('cancel') }}</button>
        </div>
      </div>
