<script>
function setLang(l){
  document.body.setAttribute('data-lang',l);
  document.getElementById('btn-tr').classList.toggle('active',l==='tr');
  document.getElementById('btn-en').classList.toggle('active',l==='en');
  document.documentElement.lang=l;
}

const sids=['s1','s2','s3','s4','s5','s6','s7','s8','s9','s10'];

function goTo(id){
  const el=document.getElementById(id);
  if(!el)return;
  window.scrollTo({top:el.getBoundingClientRect().top+window.scrollY-76,behavior:'smooth'});
  document.getElementById('sb').classList.remove('open');
}

function updateActive(){
  let cur='s1';
  sids.forEach(id=>{const el=document.getElementById(id);if(el&&window.scrollY+110>=el.offsetTop)cur=id;});
  document.querySelectorAll('.slink').forEach((l,i)=>l.classList.toggle('active',sids[i]===cur));
}

function updateProg(){
  const d=document.documentElement.scrollHeight-window.innerHeight;
  document.getElementById('prog').style.transform=`scaleX(${d>0?window.scrollY/d:0})`;
}

function reveal(){
  document.querySelectorAll('.sec').forEach(s=>{
    if(s.getBoundingClientRect().top<window.innerHeight*.93)s.classList.add('vis');
  });
}

window.addEventListener('scroll',()=>{updateActive();updateProg();reveal();},{passive:true});
setTimeout(reveal,80);

// Search
const srch=document.getElementById('srch');
let hl=[];
srch.addEventListener('input',function(){
  hl.forEach(m=>{const p=m.parentNode;if(p){p.replaceChild(document.createTextNode(m.textContent),m);}});
  hl=[];
  const q=this.value.trim().toLowerCase();
  if(q.length<2)return;
  const main=document.querySelector('.main');
  const tw=document.createTreeWalker(main,NodeFilter.SHOW_TEXT,null);
  const ns=[];let n;
  while((n=tw.nextNode()))if(n.nodeValue.toLowerCase().includes(q))ns.push(n);
  ns.slice(0,40).forEach(n=>{
    const s=document.createElement('span');
    s.innerHTML=n.nodeValue.replace(new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi'),'<mark>$1</mark>');
    n.parentNode.replaceChild(s,n);
    hl.push(...s.querySelectorAll('mark'));
  });
  if(hl[0])hl[0].scrollIntoView({behavior:'smooth',block:'center'});
});

function cpBlock(btn){
  const pre=btn.closest('.cb').querySelector('pre');
  navigator.clipboard.writeText(pre.innerText).then(()=>{btn.textContent='Copied!';setTimeout(()=>btn.textContent='Copy',1800);});
}

function cpText(t,el){
  const orig=el.innerHTML;
  navigator.clipboard.writeText(t).then(()=>{
    el.innerHTML=t+' <span style="color:var(--green);font-size:13px;margin-left:8px">✓ Copied!</span>';
    setTimeout(()=>el.innerHTML=orig,2000);
  });
}

function toggleSB(){document.getElementById('sb').classList.toggle('open');}
document.querySelector('.main').addEventListener('click',()=>document.getElementById('sb').classList.remove('open'));
</script>
