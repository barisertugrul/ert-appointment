		global $wpdb;
		$table = $this->table();

		// Priority: exact scope → fall back to global.
		if ( $scope !== 'global' && $scopeId !== null ) {
			$row = $wpdb->get_row(
				$wpdb->prepare( 'SELECT * FROM %i WHERE scope=%s AND scope_id=%d AND is_active=1 LIMIT 1', $table, $scope, $scopeId ),
