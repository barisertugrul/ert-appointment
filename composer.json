{
  "name": "ert-appointment/ert-appointment",
  "description": "ERT Appointment — Lite plugin",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.10",
    "squizlabs/php_codesniffer": "^3.7",
    "wp-coding-standards/wpcs": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "ERTAppointment\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ERTAppointment\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test":   "phpunit --configuration phpunit.xml",
    "lint":   "phpcs --standard=phpcs.xml.dist -n src/",
    "lint:strict": "phpcs --standard=phpcs.xml.dist src/",
    "lint:fix": "phpcbf --standard=phpcs.xml.dist src/",
    "analyse": "phpstan analyse src/ --level=8"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
