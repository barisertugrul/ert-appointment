namespace ERTAppointment\Domain\Appointment;
namespace ERTAppointment\Domain\Department;
namespace ERTAppointment\Domain\Provider;
namespace ERTAppointment\Domain\Schedule;
namespace ERTAppointment\Domain\Notification;
namespace ERTAppointment\Infrastructure\Cache;
namespace ERTAppointment\Infrastructure\Repositories;
namespace ERTAppointment\Api\Controllers;
namespace ERTAppointment\Settings;
```

